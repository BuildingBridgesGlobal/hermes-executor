# Hermes Executor — sandbox execution service.
# Copy this file to .env and fill in real values before running.

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Required: API key shared with huvia-core callers.
# Prefer HERMES_EXECUTOR_API_KEY. HUVIA_API_KEY is accepted for legacy setups.
HERMES_EXECUTOR_API_KEY=placeholder

# Legacy fallback key (optional). Used only when HERMES_EXECUTOR_API_KEY is not set.
HUVIA_API_KEY=placeholder

# -----------------------------------------------------------------------------
# Runtime (optional)
# -----------------------------------------------------------------------------

# Absolute path for sandbox working directories. Defaults to /tmp/hermes-sandboxes.
# SANDBOX_BASE_DIR=/tmp/hermes-sandboxes

# Server port. Defaults to 8000.
# PORT=8000
