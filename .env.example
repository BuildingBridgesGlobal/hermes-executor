# Hermes Executor — sandbox execution service.
# Copy this file to .env and fill in real values before running.

# Required: API key shared with huvia-core callers.
# Prefer HERMES_EXECUTOR_API_KEY. HUVIA_API_KEY is accepted for legacy setups.
HERMES_EXECUTOR_API_KEY=he_live_...

# Optional: absolute path for sandbox working directories.
# Defaults to /tmp/hermes-sandboxes if omitted.
# SANDBOX_BASE_DIR=/tmp/hermes-sandboxes

# Optional: server port. Defaults to 8000.
# PORT=8000
